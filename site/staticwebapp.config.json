{
  "routes": [
    { "route": "/admin", "redirect": "/admin/", "statusCode": 301 },
    { "route": "/admin/*", "allowedRoles": ["admin"] },
    { "route": "/api/manage/*", "allowedRoles": ["admin"] },
    { "route": "/api/get-roles", "allowedRoles": ["authenticated", "anonymous"] },
    { "route": "/api/training-requests", "allowedRoles": ["anonymous"] }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/github?post_login_redirect_uri=/admin/",
      "statusCode": 302
    }
  },
  "auth": {
    "rolesSource": "/api/get-roles",
    "identityProviders": {
      "github": {
        "registration": {
          "clientIdSettingName": "GITHUB_CLIENT_ID",
          "clientSecretSettingName": "GITHUB_CLIENT_SECRET"
        }
      }
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/admin/*",
      "/_next/*",
      "/.auth/*",
      "*.{css,js,png,jpg,jpeg,gif,svg,ico,webp,mp4,json,xml,txt,woff,woff2}"
    ]
  }
}
